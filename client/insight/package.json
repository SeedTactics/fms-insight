{
  "name": "@seedtactics/insight-client",
  "version": "16.8.4-beta.0",
  "license": "BSD-3-Clause",
  "repository": {
    "url": "https://github.com/SeedTactics/fms-insight"
  },
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "exports": {
    "./bootstrap": "./dist/bootstrap.js",
    "./cell-status/*": "./dist/cell-status/*.js",
    "./components/*": "./dist/components/*.js",
    "./components/analysis/*": "./dist/components/analysis/*.js",
    "./components/operations/*": "./dist/components/operations/*.js",
    "./components/quality/*": "./dist/components/quality/*.js",
    "./components/station-monitor/*": "./dist/components/station-monitor/*.js",
    "./data/*": "./dist/data/*.js",
    "./network/*": "./dist/network/*.js",
    "./util/*": "./dist/util/*.js"
  },
  "scripts": {
    "type-check": "tsc --noEmit --skipLibCheck",
    "lint": "oxlint --type-aware",
    "build": "tsc --noEmit --skipLibCheck && vite build",
    "build:package": "tsc --project tsconfig.publish.json && cp -Tr ../../docs ./docs",
    "start": "vite",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --browser.headless --project integration",
    "nswag": "./node_modules/nswag/bin/nswag.js aspnetcore2openapi /project:../../server/debug-mock /output:../../server/fms-insight-api.json && ./node_modules/nswag/bin/nswag.js openapi2tsclient /UseAbortSignal:true /input:../../server/fms-insight-api.json /output:src/network/api.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.3.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@react-spring/rafz": "^10.1.2",
    "@react-spring/web": "^10.1.2",
    "@seedtactics/immutable-collections": "^1.1.1",
    "@yudiel/react-qr-scanner": "^2.6.0",
    "copy-to-clipboard": "^4.0.2",
    "d3-interpolate-path": "^2.3.0",
    "d3-sankey": "^0.12.3",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "date-fns": "^4.4.0",
    "highlight.js": "^11.11.1",
    "jdenticon": "^3.3.0",
    "jotai": "^2.20.2",
    "jotai-family": "^1.0.2",
    "jsbarcode": "^3.12.3",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.2.7",
    "react-calendar": "^6.0.1",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-resize-detector": "^12.3.0",
    "react-timeago": "^8.3.0",
    "react-to-print": "^3.3.0",
    "urlpattern-polyfill": "^10.1.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@types/d3-interpolate-path": "^2.0.3",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "jsdom": "^29.1.1",
    "nswag": "^14.7.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "pnpm@11.3.0"
}
